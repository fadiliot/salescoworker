# Application Settings
DATABASE_URL=postgresql://postgres:password@localhost:5432/sales_coworker

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Zoho CRM & Books OAuth
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8000/api/auth/callback/zoho
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CRM_API_URL=https://www.zohoapis.com/crm/v3
ZOHO_BOOKS_API_URL=https://www.zohoapis.com/books/v3
ZOHO_ORGANIZATION_ID=your_zoho_org_id

# Microsoft / Outlook OAuth (Azure App Registration)
MS_CLIENT_ID=your_ms_client_id
MS_CLIENT_SECRET=your_ms_client_secret
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/api/auth/callback/microsoft
MS_GRAPH_URL=https://graph.microsoft.com/v1.0
MS_SCOPES=Mail.ReadWrite Mail.Send Calendars.Read User.Read offline_access

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
AI_FALLBACK_ENABLED=true

# Yeastar PBX
YEASTAR_HOST=http://your-pbx-host
YEASTAR_USERNAME=your_pbx_username
YEASTAR_PASSWORD=your_pbx_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
